{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "pokedex_app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "toolArgs": [
                "--dart-define-from-file=dart_defines.json"
            ]
        },
        {
            "name": "pokedex_app (Chrome Wasm MT :5000)",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "args": [
                "--web-port=5000"
            ],
            "flutterMode": "debug",
            "toolArgs": [
                "--dart-define-from-file=dart_defines.json",
                "--wasm"
            ]
        }
    ]
}
